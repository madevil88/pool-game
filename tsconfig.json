{
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "target": "es6",
        "module": "ES2015",
        "moduleResolution": "bundler",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "declaration": true,
        "sourceMap": true,
        "lib": ["ES2022", "dom", "dom.iterable"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["src/**/__tests__/**", "node_modules"]
}
